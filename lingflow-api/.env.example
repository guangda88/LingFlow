# LingFlow REST API - 环境变量配置

# 应用配置
APP_NAME=LingFlow API
APP_VERSION=1.0.0
DEBUG=false

# 服务器
HOST=0.0.0.0
PORT=8000

# API Keys（逗号分隔）
LINGFLOW_API_KEYS=dev-key-12345,test-key-67890

# LingFlow 配置
WORK_DIR=/workspace
LOG_LEVEL=INFO

# 外部服务 Token（可选）
GITHUB_TOKEN=
NPM_TOKEN=

# 任务配置
DEFAULT_TIMEOUT=300
MAX_TASKS=100
