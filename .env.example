# LingFlow Environment Variables Example
# =====================================
#
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control!
#
# For more information, see docs/SECURITY_AUDIT_REPORT.md
#

# API Keys (if integrating with external services)
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Database Configuration (if using database features)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=lingflow
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password

# Logging Configuration
# LOG_LEVEL=INFO
# LOG_FILE=/var/log/lingflow/app.log

# Workflow Configuration
# WORKFLOW_MAX_PARALLEL=2
# WORKFLOW_MAX_ITERATIONS=100
# WORKFLOW_SLEEP_INTERVAL=0.01

# Compression Configuration
# COMPRESSION_ENABLED=true
# COMPRESSION_MAX_LENGTH=10000

# Skills Configuration
# SKILLS_PATH=skills
# SKILLS_DEFAULT_TIMEOUT=30

# Storage Configuration (if using cloud storage)
# STORAGE_TYPE=local  # Options: local, s3, gcs, azure
# STORAGE_BUCKET=lingflow-bucket
# STORAGE_REGION=us-east-1

# Notification Configuration (if using notifications)
# NOTIFICATION_ENABLED=false
# NOTIFICATION_TYPE=email  # Options: email, slack, webhook
# NOTIFICATION_ENDPOINT=https://hooks.slack.com/services/...

# Development Settings
# DEBUG=false
# ENVIRONMENT=production  # Options: development, staging, production

# Git Configuration
# GIT_WORKTREE_BASE=.worktrees
# GIT_DEFAULT_BRANCH=master
