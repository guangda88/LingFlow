#!/bin/bash
# LingFlow Pre-push Hook v2.0 - VibeCoding 渐进式部署
# 核心原则: 质量门控 + AI 辅助 + 渐进式实施

set -euo pipefail

# ==================== 初始化 ====================
PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$PROJECT_ROOT"

# 加载配置
source .githooks/config.sh

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# 统计变量
BLOCKED=0
WARNINGS=0
PASSED=0

# ==================== 日志函数 ====================
log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; ((WARNINGS++)); }
log_error() { echo -e "${RED}[BLOCK]${NC} $1"; ((BLOCKED++)); }
log_pass() { echo -e "${GREEN}[PASS]${NC} $1"; ((PASSED++)); }
log_section() { echo ""; echo -e "${BLUE}=== $1 ===${NC}"; }

# ==================== P2 检查（增强功能 - 建议性） ====================

# P2-1: 多仓库一致性检查
check_p2_multi_repo() {
    [ $HOOKS_P2_MULTI_REPO -eq 0 ] && return 0

    log_section "P2-1: 多仓库一致性检查"

    local current_branch=$(git rev-parse --abbrev-ref HEAD)
    local has_github=0
    local has_gitea=0

    # 检查远程仓库
    if git remote | grep -q "^github$"; then
        has_github=1
        log_info "GitHub: 已配置"
    fi

    if git remote | grep -q "^origin$"; then
        has_gitea=1
        log_info "Gitea: 已配置"
    fi

    if [ $has_github -eq 1 ] && [ $has_gitea -eq 1 ]; then
        log_pass "多仓库配置正常"
    else
        log_warn "建议配置 GitHub 和 Gitea 双仓库"
    fi

    return 0
}

# P2-2: 版本号一致性检查
check_p2_version() {
    log_section "P2-2: 版本号一致性检查"

    local version_files=("pyproject.toml" "setup.py")
    local versions=()
    local found_version=0

    for file in "${version_files[@]}"; do
        if [ -f "$file" ]; then
            local version=$(grep -E "version\s*=\s*['\"]" "$file" | head -1 | sed -E "s/.*=\s*['\"]([^'\"]+)['\"].*/\1/" || echo "")
            if [ -n "$version" ]; then
                versions+=("$file: $version")
                ((found_version++))
            fi
        fi
    done

    if [ $found_version -gt 0 ]; then
        log_info "发现的版本号:"
        for v in "${versions[@]}"; do
            echo "  - $v"
        done

        if [ $found_version -gt 1 ]; then
            log_warn "发现多个版本号定义，请确保一致"
        else
            log_pass "版本号检查通过"
        fi
    else
        log_info "未找到版本号定义"
    fi

    return 0
}

# 待推送提交检查
check_pending_commits() {
    log_section "待推送提交检查"

    local current_branch=$(git rev-parse --abbrev-ref HEAD)
    local pending_count=0

    # 检查各远程的待推送提交
    for remote in $(git remote); do
        if git show-ref --verify --quiet "refs/remotes/${remote}/${current_branch}" 2>/dev/null; then
            local count=$(git rev-list --count "refs/remotes/${remote}/${current_branch}..HEAD" 2>/dev/null || echo "0")
            if [ $count -gt 0 ]; then
                log_info "${remote}: $count 个提交待推送"
                ((pending_count++))
            fi
        fi
    done

    if [ $pending_count -eq 0 ]; then
        log_info "没有待推送的提交（或远程分支不存在）"
    else
        log_pass "待推送提交检查完成"
    fi

    # 显示最近的提交
    local recent_commits=$(git log --oneline -5 2>/dev/null || echo "")
    if [ -n "$recent_commits" ]; then
        echo ""
        log_info "最近的提交:"
        echo "$recent_commits" | sed 's/^/    /'
    fi

    return 0
}

# 敏感文件检查
check_sensitive_files() {
    log_section "敏感文件检查"

    local current_branch=$(git rev-parse --abbrev-ref HEAD)
    local sensitive_patterns=(".env" "*.key" "*.pem" "password" "secret" "token")
    local found_sensitive=0

    # 检查待推送的提交
    for remote in $(git remote); do
        if git show-ref --verify --quiet "refs/remotes/${remote}/${current_branch}" 2>/dev/null; then
            for pattern in "${sensitive_patterns[@]}"; do
                local files=$(git diff --name-only "refs/remotes/${remote}/${current_branch}..HEAD" | grep -E "$pattern" || true)

                if [ -n "$files" ]; then
                    log_error "发现可能的敏感文件:"
                    echo "$files" | sed 's/^/    /'
                    found_sensitive=1
                fi
            done
        fi
    done

    if [ $found_sensitive -eq 0 ]; then
        log_pass "敏感文件检查通过"
        return 0
    else
        log_error "请检查并移除敏感文件"
        return 1
    fi
}

# ==================== 主函数 ====================
main() {
    echo ""
    echo -e "${CYAN}LingFlow Pre-push Hook v2.0${NC}"
    echo -e "${CYAN}VibeCoding 渐进式部署${NC}"

    # 显示配置
    show_hooks_config

    # 从标准输入读取推送信息
    local remote=""
    local url=""

    while read -r line; do
        local local_ref=$(echo "$line" | awk '{print $1}')
        local local_sha=$(echo "$line" | awk '{print $2}')
        remote=$(echo "$line" | awk '{print $3}')
        url=$(echo "$line" | awk '{print $4}')

        log_info "推送目标: $remote ($url)"

        # 如果是删除操作，跳过检查
        if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
            log_info "删除操作，跳过检查"
            exit 0
        fi
    done

    # 运行检查
    check_p2_multi_repo || true
    check_p2_version || true
    check_pending_commits || true
    check_sensitive_files || ((BLOCKED++))

    # 总结
    echo ""
    echo -e "${BLUE}=== 检查总结 ===${NC}"
    echo -e "  通过: ${GREEN}$PASSED${NC}"
    echo -e "  警告: ${YELLOW}$WARNINGS${NC}"
    echo -e "  阻断: ${RED}$BLOCKED${NC}"
    echo ""

    # 判断是否阻断推送
    if [ $BLOCKED -gt 0 ]; then
        log_error "推送被阻断"
        echo ""
        echo "提示:"
        echo "  - 检查敏感文件并移除"
        echo "  - 或跳过检查: git push --no-verify"
        exit 1
    fi

    if [ $WARNINGS -gt 0 ]; then
        log_warn "存在警告，建议检查后再推送"
    fi

    log_pass "Pre-push 检查通过"
    log_info "准备推送到: $remote"
    exit 0
}

# 执行主函数
main "$@"
