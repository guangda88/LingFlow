#!/bin/bash
# LingFlow Pre-commit Hook v2.0 - VibeCoding 渐进式部署
# 核心原则: 质量门控 + AI 辅助 + 渐进式实施

set -euo pipefail

# ==================== 初始化 ====================
PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$PROJECT_ROOT"

# 加载配置
source .githooks/config.sh

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# 统计变量
BLOCKED=0
WARNINGS=0
PASSED=0

# ==================== 日志函数 ====================
log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; ((WARNINGS++)); }
log_error() { echo -e "${RED}[BLOCK]${NC} $1"; ((BLOCKED++)); }
log_pass() { echo -e "${GREEN}[PASS]${NC} $1"; ((PASSED++)); }
log_section() { echo ""; echo -e "${BLUE}=== $1 ===${NC}"; }

# ==================== P0 检查（基础质量 - 必需，阻断） ====================

# P0-1: Flake8 代码质量检查
check_p0_flake8() {
    [ $HOOKS_P0_FLAKE8 -eq 0 ] && return 0

    log_section "P0-1: 代码质量检查 (flake8)"

    if ! command -v flake8 &> /dev/null; then
        log_warn "flake8 未安装，跳过检查"
        return 0
    fi

    local python_files=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)
    [ -z "$python_files" ] && return 0

    log_info "检查文件: $(echo $python_files | wc -w) 个"

    # 运行 flake8
    if flake8 $python_files --max-line-length=88 --ignore=E203,W503,E501 2>&1; then
        log_pass "代码质量检查通过"
        return 0
    else
        local result=$?
        ai_suggest_fix "flake8" "$(flake8 $python_files 2>&1 | head -5)"
        quality_gate $HOOKS_P0_FLAKE8 "代码质量" $result
        return $?
    fi
}

# P0-2: 测试状态检查
check_p0_tests() {
    [ $HOOKS_P0_TESTS -eq 0 ] && return 0

    log_section "P0-2: 测试状态检查"

    if ! command -v pytest &> /dev/null; then
        log_warn "pytest 未安装，跳过检查"
        return 0
    fi

    log_info "运行快速测试..."

    # 10秒超时的快速测试
    if timeout 10 pytest tests/ -v --tb=line -x 2>&1 | head -20; then
        log_pass "测试状态检查通过"
        return 0
    else
        local result=$?
        if [ $result -eq 124 ]; then
            log_warn "测试超时（可能测试较多）"
        else
            log_warn "部分测试失败"
        fi
        ai_suggest_fix "tests" ""
        quality_gate $HOOKS_P0_TESTS "测试状态" $result
        return $?
    fi
}

# ==================== P1 检查（文档规范 - 警告性） ====================

# P1-1: 文档完整性检查
check_p1_docs() {
    [ $HOOKS_P1_DOCS -eq 0 ] && return 0

    log_section "P1-1: 文档完整性检查"

    local python_files=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)
    [ -z "$python_files" ] && return 0

    local missing_docs=0
    for file in $python_files; do
        # 检查公共函数是否有 docstring
        while IFS= read -r line; do
            if echo "$line" | grep -q "^def [a-z_][a-z0-9_]*(" && ! echo "$line" | grep -q "def _"; then
                local func_name=$(echo "$line" | sed 's/def \([a-z_][a-z0-9_]*\).*/\1/')
                if ! grep -A 5 "$line" "$file" | grep -q '"""'; then
                    log_warn "$file: 函数 $func_name 缺少文档字符串"
                    ((missing_docs++))
                fi
            fi
        done < "$file"
    done

    if [ $missing_docs -eq 0 ]; then
        log_pass "文档完整性检查通过"
    else
        log_warn "发现 $missing_docs 处缺少文档"
        ai_suggest_fix "docs" ""
        quality_gate $HOOKS_P1_DOCS "文档完整性" 1
    fi

    return 0
}

# P1-2: 代码格式检查
check_p1_format() {
    [ $HOOKS_P1_FORMAT -eq 0 ] && return 0

    log_section "P1-2: 代码格式检查 (black)"

    if ! command -v black &> /dev/null; then
        log_warn "black 未安装，跳过检查"
        return 0
    fi

    local python_files=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)
    [ -z "$python_files" ] && return 0

    if black --check $python_files 2>/dev/null; then
        log_pass "代码格式检查通过"
        return 0
    else
        log_warn "代码格式不符合规范"
        ai_suggest_fix "format" ""
        quality_gate $HOOKS_P1_FORMAT "代码格式" 1
        return $?
    fi
}

# ==================== P2 检查（增强功能 - 建议性） ====================

# P2-1: 代码复杂度检查
check_p2_complexity() {
    [ $HOOKS_P2_COMPLEXITY -eq 0 ] && return 0

    log_section "P2-1: 代码复杂度检查"

    local python_files=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)
    [ -z "$python_files" ] && return 0

    local complex_files=0
    for file in $python_files; do
        while IFS= read -r line; do
            if echo "$line" | grep -q "^def [a-z_][a-z0-9_]*("; then
                local func_start=$(grep -n "$line" "$file" | cut -d: -f1)
                local func_end=$(tail -n +$((func_start + 1)) "$file" | grep -n "^def \|^class" | head -1 | cut -d: -f1)
                [ -z "$func_end" ] && func_end=$(wc -l < "$file")
                local func_lines=$((func_end - 1))

                if [ $func_lines -gt 50 ]; then
                    log_warn "$file: 函数超过 50 行 ($func_lines 行)"
                    ((complex_files++))
                fi
            fi
        done < "$file"
    done

    if [ $complex_files -eq 0 ]; then
        log_pass "代码复杂度检查通过"
    else
        log_warn "发现 $complex_files 处复杂度较高"
        ai_suggest_fix "complexity" ""
        quality_gate $HOOKS_P2_COMPLEXITY "代码复杂度" 1
    fi

    return 0
}

# ==================== 主函数 ====================
main() {
    echo ""
    echo -e "${CYAN}LingFlow Pre-commit Hook v2.0${NC}"
    echo -e "${CYAN}VibeCoding 渐进式部署${NC}"

    # 显示配置
    show_hooks_config

    # 获取暂存的文件
    local staged_files=$(git diff --cached --name-only --diff-filter=ACM)
    if [ -z "$staged_files" ]; then
        log_info "没有文件被暂存"
        exit 0
    fi

    log_info "检查的文件: $(echo $staged_files | wc -w) 个"

    # 按优先级执行检查
    # P0 检查（必需，可能阻断）
    check_p0_flake8 || true
    check_p0_tests || true

    # P1 检查（警告，不阻断）
    check_p1_docs || true
    check_p1_format || true

    # P2 检查（建议，不阻断）
    check_p2_complexity || true

    # 总结
    echo ""
    echo -e "${BLUE}=== 检查总结 ===${NC}"
    echo -e "  通过: ${GREEN}$PASSED${NC}"
    echo -e "  警告: ${YELLOW}$WARNINGS${NC}"
    echo -e "  阻断: ${RED}$BLOCKED${NC}"
    echo ""

    # 判断是否阻断提交
    if [ $BLOCKED -gt 0 ]; then
        log_error "提交被阻断，请修复 P0 级别的错误"
        echo ""
        echo "提示:"
        echo "  - 查看 BLOCK 标记的错误并修复"
        echo "  - 或使用快速迭代模式: HOOKS_FAST_ITERATION=1 git commit"
        echo "  - 或跳过检查: git commit --no-verify"
        exit 1
    fi

    if [ $WARNINGS -gt 0 ]; then
        log_warn "存在警告，建议修复后再提交"
    fi

    log_pass "Pre-commit 检查通过"
    exit 0
}

# 执行主函数
main "$@"
