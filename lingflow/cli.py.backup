@cli.group()
def test():
    """测试系统"""
    pass


@test.command()
@click.option("--coverage",
              is_flag=True,
              help="生成覆盖率报告")
@click.option("--verbose", "-v",
              is_flag=True,
              help="详细输出")
@click.option("--parallel",
              is_flag=True,
              help="并行运行测试")
@click.option("--target",
              help="目标测试路径")
def run_test(coverage, verbose, parallel, target):
    """运行测试套件"""
    import subprocess

    click.echo(f"\n🧪 运行测试套件...")

    # 构建pytest命令
    cmd = ["python", "-m", "pytest"]

    if verbose:
        cmd.append("-v")
    else:
        cmd.append("-q")

    if coverage:
        cmd.extend(["--cov=lingflow", "--cov-report=term-missing"])

    if parallel:
        cmd.extend(["-n", "auto"])

    if target:
        cmd.append(target)

    click.echo(f"命令: {' '.join(cmd)}")

    # 运行测试
    result = subprocess.run(cmd)
    sys.exit(result.returncode)


