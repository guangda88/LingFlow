{
  "name": "code-review-js",
  "version": "1.0.0",
  "description": "JavaScript/TypeScript 代码审查技能",
  "category": "code_review",
  "languages": ["javascript", "typescript", "node.js", "jsx", "tsx"],
  "entry_point": "implementation.py",
  "class_name": "JavaScriptCodeReviewSkill",
  
  "capabilities": {
    "code_quality": {
      "enabled": true,
      "tools": ["eslint"],
      "description": "代码质量检查，包括 ESLint 规则、代码风格、复杂度"
    },
    "architecture": {
      "enabled": true,
      "tools": ["package.json analyzer"],
      "description": "架构设计检查，包括模块化、依赖管理、项目结构"
    },
    "performance": {
      "enabled": true,
      "tools": ["performance analyzer"],
      "description": "性能分析，包括异步优化、内存管理、V8 优化"
    },
    "security": {
      "enabled": true,
      "tools": ["npm audit", "security scanner"],
      "description": "安全检查，包括漏洞检测、危险函数、XSS/CSRF 防护"
    },
    "maintainability": {
      "enabled": true,
      "tools": ["documentation checker"],
      "description": "可维护性检查，包括文档完整性、代码注释、代码组织"
    },
    "best_practices": {
      "enabled": true,
      "tools": ["best practices checker"],
      "description": "最佳实践检查，包括 ES6+ 特性、错误处理、编码标准"
    },
    "autoresearch_consistency": {
      "enabled": true,
      "tools": ["consistency checker"],
      "description": "AutoResearch 一致性检查，包括代码风格、命名规范、设计一致性"
    },
    "bugs": {
      "enabled": true,
      "tools": ["bug analyzer"],
      "description": "Bug 分析，包括运行时错误、类型错误、边界条件"
    }
  },
  
  "tools": {
    "eslint": {
      "name": "ESLint",
      "version": ">=8.0.0",
      "required": true,
      "description": "JavaScript 代码检查工具"
    },
    "npm": {
      "name": "npm",
      "version": ">=6.0.0",
      "required": true,
      "description": "Node.js 包管理器"
    },
    "typescript": {
      "name": "TypeScript",
      "version": ">=4.0.0",
      "required": false,
      "description": "TypeScript 编译器（仅用于 TypeScript 项目）"
    }
  },
  
  "config": {
    "exclude_dirs": [
      "node_modules",
      "dist",
      "build",
      ".git",
      "__pycache__",
      "coverage"
    ],
    "file_extensions": [
      ".js",
      ".jsx",
      ".ts",
      ".tsx",
      ".mjs",
      ".cjs"
    ],
    "max_file_size": 10240,
    "severity_levels": {
      "critical": 0,
      "high": 1,
      "medium": 2,
      "low": 3
    }
  },
  
  "output": {
    "formats": ["markdown", "json"],
    "default_format": "markdown",
    "include_details": true,
    "include_stats": true,
    "include_recommendations": true
  },
  
  "requirements": {
    "python": ">=3.8",
    "node": ">=14.0.0",
    "eslint": ">=8.0.0"
  },
  
  "meta": {
    "author": "lingflow Team",
    "license": "MIT",
    "repository": "https://github.com/lingflow/skills/code-review-js",
    "documentation": "SKILL.md",
    "created_at": "2026-03-23",
    "updated_at": "2026-03-23"
  }
}
