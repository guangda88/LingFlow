      "path": "skills/finishing-a-development-branch/SKILL.md",
      "triggers": [
        "done",
        "complete",
        "finish",
        "ready to merge"
      ]
    },
    {
      "name": "requesting-code-review",
      "description": "根据计划进行代码审查，按严重程度报告问题",
      "path": "skills/requesting-code-review/SKILL.md",
      "triggers": [
        "review",
        "code review",
        "check code"
      ]
    },
    {
      "name": "receiving-code-review",
