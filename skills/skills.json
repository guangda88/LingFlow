  "settings": {
    "auto_trigger": true,
    "strict_mode": true,
    "require_approval": {
      "brainstorming": false,
      "writing-plans": true,
      "test-driven-development": false,
      "subagent-driven-development": true
    },
    "documentation_paths": {
