{
  "skills": [
    {
      "name": "brainstorming",
      "description": "在任何创造性工作前必须使用 - 创建功能、构建组件、添加功能或修改行为。在实施前探索用户意图、需求和设计。",
      "path": "skills/brainstorming/SKILL.md",
      "triggers": [
        "feature",
        "build",
        "create",
        "implement",
        "add functionality",
        "modify behavior"
      ]
    },
    {
      "name": "writing-plans",
      "description": "当你有规格或需求需要多步骤任务时，在接触代码之前使用",
      "path": "skills/writing-plans/SKILL.md",
      "triggers": [
        "plan",
        "implementation plan",
        "break down",
        "spec"
      ],
      "depends_on": ["brainstorming"]
    },
    {
      "name": "test-driven-development",
      "description": "强制 RED-GREEN-REFACTOR：写失败的测试，看着它失败，写最少代码，看着它通过，提交",
      "path": "skills/test-driven-development/SKILL.md",
      "triggers": [
        "test",
        "write test",
        "implement",
        "code"
      ],
      "depends_on": ["writing-plans"]
    },
    {
      "name": "systematic-debugging",
      "description": "4 阶段根本原因过程（观察、隔离、假设、验证）",
      "path": "skills/systematic-debugging/SKILL.md",
      "triggers": [
        "debug",
        "fix",
        "error",
        "issue",
        "broken",
        "not working"
      ]
    },
    {
      "name": "subagent-driven-development",
      "description": "快速迭代配合两阶段审查（规范符合性，然后代码质量）",
      "path": "skills/subagent-driven-development/SKILL.md",
      "triggers": [
        "execute plan",
        "implement plan",
        "start coding"
      ],
      "depends_on": ["writing-plans"]
    },
    {
      "name": "verification-before-completion",
      "description": "确保问题真正修复，不要假设",
      "path": "skills/verification-before-completion/SKILL.md",
      "triggers": [
        "verify",
        "check",
        "confirm fix"
      ]
    },
    {
      "name": "using-git-worktrees",
      "description": "为功能开发创建隔离的工作空间，实现安全的并行开发",
