      "path": "skills/receiving-code-review/SKILL.md",
      "triggers": [
        "respond to review",
        "address feedback"
      ]
    },
    {
      "name": "executing-plans",
      "description": "带检查点的批量执行（未来实现）",
      "path": "skills/executing-plans/SKILL.md",
      "triggers": [
