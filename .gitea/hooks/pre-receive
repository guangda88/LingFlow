#!/bin/bash
# Gitea Pre-receive Hook for LingFlow
# 位置：在 Gitea 服务器端的 /var/lib/gitea/repositories/guangda/LingFlow.git/hooks/pre-receive
# 权限：chmod +x pre-receive

set -e

# 配置
BRANCH_PROTECTED="master"
MIN_REVIEWERS=1
MAX_FILE_SIZE=10485760  # 10MB

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1" >&2
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1" >&2
}

# 检查是否是保护分支
check_protected_branch() {
    local refname=$1
    local branch=$(echo "$refname" | sed -e 's/^refs\/heads\///')

    if [ "$branch" = "$BRANCH_PROTECTED" ]; then
        return 0
    fi
    return 1
}

# 检查提交信息格式
check_commit_message() {
    local commit=$1
    local msg=$(git log -1 --format=%B $commit)

    # 必须遵循 Conventional Commits
    if ! [[ "$msg" =~ ^(feat|fix|docs|refactor|chore|test|perf|style|revert): ]]; then
        log_error "Invalid commit message format:"
        log_error "  Commit: $commit"
        log_error "  Message: $msg"
        log_error ""
        log_error "Required format: (feat|fix|docs|refactor|chore|test|perf|style): description"
        return 1
    fi

    # 检查是否有空的提交信息
    if [ -z "$(echo "$msg" | sed 's/^$/|' | head -1)" ]; then
        log_error "Empty commit message for commit $commit"
        return 1
    fi

    return 0
}

# 检查文件大小
check_file_size() {
    local newref=$1
    local oldref=$2

    # 获取新增的文件
    while IFS= read -r file; do
        if [ -n "$file" ]; then
            local size=$(git cat-file -s "$newref:$file" 2>/dev/null || echo 0)
            if [ "$size" -gt "$MAX_FILE_SIZE" ]; then
                log_error "File too large: $file ($size bytes, max $MAX_FILE_SIZE bytes)"
                return 1
            fi
        fi
    done < <(git diff --name-only --diff-filter=A "$oldref" "$newref")

    return 0
}

# 检查敏感文件
check_sensitive_files() {
    local newref=$1
    local oldref=$2

    # 获取变更的文件
    while IFS= read -r file; do
        if [ -n "$file" ]; then
            # 检查文件名
            local filename=$(basename "$file")

            # 禁止的文件名模式
            case "$filename" in
                *.pem|*.key|*.id_rsa|*.p12|*.pfx|*.jks)
                    log_error "Prohibited file: $file (private key/certificate)"
                    return 1
                    ;;
                .env|*.env|credentials.json|secrets.json|config.secrets.yaml)
                    log_error "Prohibited file: $file (secrets file)"
                    return 1
                    ;;
            esac

            # 检查文件内容（仅文本文件）
            if git show "$newref:$file" >/dev/null 2>&1; then
                local content=$(git show "$newref:$file" 2>/dev/null || true)

                # 检查常见密钥模式
                if echo "$content" | grep -iE "(password\s*=\s*[\"'].*[\"']|api_key\s*=\s*[\"'].*[\"']|secret\s*=\s*[\"'].*[\"']|token\s*=\s*[\"'].*[\"']|private_key|aws_access_key_id|aws_secret_access_key|github_token)" | grep -v "example\|placeholder\|TODO\|XXX" >/dev/null 2>&1; then
                    log_error "Potential secret detected in: $file"
                    log_error "  Please remove sensitive data before committing"
                    return 1
                fi
            fi
        fi
    done < <(git diff --name-only "$oldref" "$newref")

    return 0
}

# 检查 Python 文件语法
check_python_syntax() {
    local newref=$1
    local oldref=$2

    while IFS= read -r file; do
        if [ -n "$file" ] && [[ "$file" == *.py ]]; then
            if ! git show "$newref:$file" | python3 -m py_compile >/dev/null 2>&1; then
                log_error "Python syntax error in: $file"
                return 1
            fi
        fi
    done < <(git diff --name-only "$oldref" "$newref")

    return 0
}

# 主逻辑
main() {
    # 读取输入
    read oldrev newrev refname

    log_info "Pre-receive hook triggered for $refname"
    log_info "  Old revision: $oldrev"
    log_info "  New revision: $newrev"

    # 如果不是保护分支，允许推送
    if ! check_protected_branch "$refname"; then
        log_info "Not a protected branch, allowing push"
        exit 0
    fi

    log_info "Protected branch detected: $BRANCH_PROTECTED"

    # 如果是新分支，oldrev 是全零
    if [ "$oldrev" = "0000000000000000000000000000000000000000" ]; then
        log_info "New branch creation"
        oldrev=$(git rev-list --max-parents=0 HEAD)
    fi

    # 获取所有提交
    local commits=$(git rev-list $oldrev..$newrev)
    local commit_count=$(echo "$commits" | grep -c "^" || echo "0")

    log_info "Checking $commit_count commit(s)"

    # 检查每个提交
    while IFS= read -r commit; do
        if [ -n "$commit" ]; then
            if ! check_commit_message "$commit"; then
                exit 1
            fi
        fi
    done <<< "$commits"

    # 检查文件大小
    if ! check_file_size "$newref" "$oldrev"; then
        exit 1
    fi

    # 检查敏感文件
    if ! check_sensitive_files "$newref" "$oldrev"; then
        exit 1
    fi

    # 检查 Python 语法
    if ! check_python_syntax "$newrev" "$oldrev"; then
        exit 1
    fi

    log_info "All checks passed! ✅"
    exit 0
}

# 执行主逻辑
main "$@"
